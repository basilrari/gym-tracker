# Supabase - get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Direct Postgres (for running migrations from terminal). From Supabase: Project Settings → Database → Connection string → URI
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Optional: for Playwright e2e tests (templates, reorder, add set, edit name, etc.)
# E2E_TEST_EMAIL=your-test-user@example.com
# E2E_TEST_PASSWORD=your-test-password
